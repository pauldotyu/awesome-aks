  "templating": {
    "list": [
      {
        "name": "prom_ds",
        "label": "Prometheus Datasource",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "regex": "",
        "skipUrlSync": false,
        "multi": false,
        "includeAll": false
      },
      {
        "name": "pyroscope_ds",
        "label": "Pyroscope Datasource",
        "type": "datasource",
        "query": "grafana-pyroscope-datasource",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "regex": "",
        "skipUrlSync": false,
        "multi": false,
        "includeAll": false
      },
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prom_ds}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(mem_alloc_bytes_total, cluster)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "current": {},
        "regex": ""
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prom_ds}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(mem_alloc_bytes_total{cluster=~\"$cluster\"}, k8s_namespace)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "regex": ""
      },
      {
        "name": "pod",
        "label": "Pod",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prom_ds}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(mem_alloc_bytes_total{cluster=~\"$cluster\",k8s_namespace=~\"$namespace\"}, k8s_podname)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "regex": ""
      }

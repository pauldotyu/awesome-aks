          "range": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom_ds}"
          }
        }
      ],
      "title": "GPU Active Memory by Pod",
      "description": "Currently allocated GPU memory (CUDA) per pod (allocations - frees - implicit frees). Note: only workloads started after profiling was enabled are tracked; pre-existing allocations are not visible.",
      "type": "timeseries"

          "editorMode": "code",
          "expr": "sum by (k8s_podname, pid) (\n  (mem_alloc_bytes_total{cluster=~\"$cluster\",k8s_namespace=~\"$namespace\",k8s_podname=~\"$pod\",host_raw=\"0\"} - mem_free_bytes_total{cluster=~\"$cluster\",k8s_namespace=~\"$namespace\",k8s_podname=~\"$pod\",host_raw=\"0\"} - mem_implicit_free_bytes_total{cluster=~\"$cluster\",k8s_namespace=~\"$namespace\",k8s_podname=~\"$pod\",host_raw=\"0\"})\n)",
